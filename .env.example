# Required for AI checklist generation (server-side only, never exposed to the browser)
OPENAI_API_KEY=sk-...

# Optional: enables real $9 checkout. Without it, "Unlock" falls back to a dev unlock.
STRIPE_SECRET_KEY=sk_live_or_test_...

# Optional: canonical site URL used for metadata, sitemap, and robots.
NEXT_PUBLIC_SITE_URL=https://relochecklist.vercel.app

# Optional: Mixpanel product-analytics token (public, exposed to the browser).
# Consent-gated: no events fire until the visitor accepts analytics cookies.
# Falls back to the committed default token when unset.
NEXT_PUBLIC_MIXPANEL_TOKEN=

# Only needed to refresh the cached country-advisory snapshot
# (node scripts/fetch-advisory.mjs). The app itself reads the committed
# snapshot and never calls the API at request time. traveladvisory.io free
# tier: 250 requests/month, 10 requests/minute.
TRAVELADVISORY_API_KEY=...
# WAQI (aqicn.org) token for scripts/fetch-opendata.mjs air quality
WAQI_TOKEN=

# Optional: OpenAQ v3 API key (free at explore.openaq.org). Enables the
# recent PM2.5 reading in the /api/climate-twin comparison. Without it the
# climate twin still works from Open-Meteo (temperature, rain, humidity).
OPENAQ_API_KEY=
