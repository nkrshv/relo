# Required for AI checklist generation (server-side only, never exposed to the browser)
OPENAI_API_KEY=sk-...

# Optional: enables the real $9 checkout via Lemon Squeezy. Without all three,
# "Unlock" falls back to a dev unlock. Use test-mode values while iterating.
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_ID=
# Signing secret for the Lemon Squeezy webhook (Settings → Webhooks). Required
# for POST /api/webhooks/lemonsqueezy to accept payloads; requests without a
# valid HMAC-SHA256 signature are rejected.
LEMONSQUEEZY_WEBHOOK_SECRET=

# Optional: Resend API key for the "here's your permanent link" email sent
# after a verified payment. Sent from hello@send.reloka.to. Without it the
# buyer still has the on-screen copy link; no email goes out.
RESEND_API_KEY=

# Optional: canonical site URL used for metadata, sitemap, and robots.
NEXT_PUBLIC_SITE_URL=https://relochecklist.vercel.app

# Optional: Mixpanel product-analytics token (public, exposed to the browser).
# Consent-gated: no events fire until the visitor accepts analytics cookies.
# Falls back to the committed default token when unset.
NEXT_PUBLIC_MIXPANEL_TOKEN=
# Mixpanel ingestion host. Defaults to the EU endpoint because the project has
# EU data residency. Set to https://api.mixpanel.com for a US-residency project.
NEXT_PUBLIC_MIXPANEL_API_HOST=

# Optional but recommended: shared cross-instance rate limiting + a global
# daily OpenAI token budget for /api/generate. Without these the limits fall
# back to per-instance in-memory counters (weak on serverless). Either the
# Upstash names or the Vercel KV names work; the Vercel KV integration injects
# the KV_* pair automatically.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# Global daily OpenAI token cap. Defaults to 250000 (the shared free-tier
# gpt-4o daily allowance). Lower it to leave headroom for other usage.
OPENAI_DAILY_TOKEN_BUDGET=

# Only needed to refresh the cached country-advisory snapshot
# (node scripts/fetch-advisory.mjs). The app itself reads the committed
# snapshot and never calls the API at request time. traveladvisory.io free
# tier: 250 requests/month, 10 requests/minute.
TRAVELADVISORY_API_KEY=...
# WAQI (aqicn.org) token for scripts/fetch-opendata.mjs air quality
WAQI_TOKEN=

# Optional: OpenAQ v3 API key (free at explore.openaq.org). Enables the
# recent PM2.5 reading in the /api/climate-twin comparison. Without it the
# climate twin still works from Open-Meteo (temperature, rain, humidity).
OPENAQ_API_KEY=

# Optional: Travelpayouts/Aviasales Data API token (server-side only). Enables
# the "Flights from ~$X" price hint on the flight task in the "before" phase.
# Without it the task still shows a plain "Search flights on Aviasales" link.
TRAVELPAYOUTS_API_TOKEN=
# Public Travelpayouts affiliate marker used in the aviasales.com links.
# Defaults to the committed marker when unset.
AVIASALES_MARKER=
